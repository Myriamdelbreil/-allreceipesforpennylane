<!DOCTYPE html>
<html>
  <head>
    <title>Allreceipesforpennylane</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  </head>

  <body>
    <div class="container">
      <ul class="list-inline tabs-underlined">
        <li>
          <%= link_to "Recipes", recipes_path, class: "tab-underlined #{'active' if current_page?(recipes_path)}"%>
        </li>
        <li>
          <%= link_to "Categories", categories_path, class: "tab-underlined #{'active' if current_page?(categories_path)}"%>
        </li>
      </ul>
    </div>
    <%= yield %>
  </body>
</html>
